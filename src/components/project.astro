---
import '../styles/global.css';

const {title, icon, color, link, github, desc} = Astro.props;
---

<div class="cursor-pointer rounded-xl overflow-hidden shadow hover:shadow-lg transition border hover:border-green-400 p-4 mt-4">
    <div class="flex items-center space-x-3 mb-2">
        {icon && (
            <span class="flex-shrink-0" style={`color: ${color || '#22c55e'}`}>
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-8 h-8">
                    <path d={icon} />
                </svg>
            </span>
        )}
        <h3 class="text-lg font-semibold text-white">{title}</h3>
    </div>
    <p class="text-white mt-2">{desc}</p>
    <div class="mt-4">
        {link && (<a href={link} class="text-blue-400 hover:underline mr-4" target="_blank">Live Link</a>)}
        {github && (<a href={github} class="text-blue-400 hover:underline" target="_blank">GitHub</a>)}
    </div>
</div>
