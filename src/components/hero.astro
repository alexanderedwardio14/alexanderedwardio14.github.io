            <h2 class="text-2xl font-bold mb-4 text-white hover:underline decoration-wavy">Tech Stack</h2>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                <div class="flex flex-col">
                    <h3 class="text-lg font-semibold text-green-400 mb-1">DevOps & Automation</h3>
                    <ul class="text-white space-y-1">
                        <li>Ansible</li>
                        <li>CI/CD</li>
                        <li>Shell Scripting</li>
                        <li>Git / GitHub</li>
                    </ul>
                </div>
                <div class="flex flex-col">
                    <h3 class="text-lg font-semibold text-green-400 mb-1">Containers & Orchestration</h3>
                    <ul class="text-white space-y-1">
                        <li>Docker</li>
                        <li>Kubernetes</li>
                        <li>Linux Administration</li>
                    </ul>
                </div>
                <div class="flex flex-col">
                    <h3 class="text-lg font-semibold text-green-400 mb-1">Programming</h3>
                    <ul class="text-white space-y-1">
                        <li>C# / .NET</li>
                        <li>SQL</li>
                        <li>Python (basic)</li>
                    </ul>
                </div>
                <div class="flex flex-col">
                    <h3 class="text-lg font-semibold text-green-400 mb-1">Infrastructure</h3>
                    <ul class="text-white space-y-1">
                        <li>Server Management</li>
                        <li>Networking</li>
                        <li>System Troubleshooting</li>
                    </ul>
                </div>
                <div class="flex flex-col">
                    <h3 class="text-lg font-semibold text-green-400 mb-1">Monitoring</h3>
                    <ul class="text-white space-y-1">
                        <li>Grafana</li>
                        <li>Observability</li>
                    </ul>
                </div>
                <div class="flex flex-col">
                    <h3 class="text-lg font-semibold text-green-400 mb-1">Enterprise</h3>
                    <ul class="text-white space-y-1">
                        <li>Pega Platform</li>
                        <li>Workflow Automation</li>
